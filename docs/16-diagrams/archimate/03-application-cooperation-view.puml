left to right direction

ApplicationComponent(web_mobile, "Canales web/mobile")
ApplicationComponent(api_gateway, "API Management / Gateway")
ApplicationComponent(ciam, "CIAM")
ApplicationComponent(customer_service, "Customer Domain Service")
ApplicationComponent(card_service, "Card Domain Service")
