@startuml
!include <archimate/Archimate>
title Security & IAM View

left to right direction

Business_Actor(customer, "Cliente")
Business_Actor(employee, "Colaborador")
Business_Actor(merchant, "Comercio")
Business_Role(customer_role, "Usuario digital")
Business_Role(admin_role, "Usuario administrativo")
Business_Role(merchant_role, "Usuario comercio")

Application_Component(canal, "Canal digital")
Application_Component(ciam, "CIAM")
Application_Component(iam, "IAM corporativo")
Application_Component(api_gateway, "API Gateway")
Application_Component(domain_services, "Servicios de dominio")
Application_Component(audit, "Audit / SIEM")
Application_Component(secrets, "Secrets / KMS")

Application_Service(authn, "Autenticación")
Application_Service(authz, "Autorización")
Application_Service(mfa, "MFA / Passwordless")
Application_Service(consent, "Gestión de consentimiento")
Application_Service(token_service, "Token service")
Application_Service(audit_service, "Auditoría de seguridad")

Data_Object(identity_data, "Identidad digital")
Data_Object(consent_data, "Consentimientos")
Data_Object(audit_event, "Eventos de auditoría")
Data_Object(secret_data, "Secretos / llaves")

Rel_Assignment(customer, customer_role)
Rel_Assignment(employee, admin_role)
Rel_Assignment(merchant, merchant_role)

Rel_Flow(customer_role, canal)
Rel_Flow(merchant_role, canal)
Rel_Flow(canal, ciam)
Rel_Flow(employee, iam)
Rel_Flow(ciam, api_gateway)
Rel_Flow(iam, api_gateway)
Rel_Flow(api_gateway, domain_services)
Rel_Flow(domain_services, audit)

Rel_Serving(ciam, authn)
Rel_Serving(ciam, authz)
Rel_Serving(ciam, mfa)
Rel_Serving(ciam, consent)
Rel_Serving(ciam, token_service)
Rel_Serving(audit, audit_service)

Rel_Access(ciam, identity_data)
Rel_Access(ciam, consent_data)
Rel_Access(audit, audit_event)
Rel_Access(secrets, secret_data)
Rel_Serving(secrets, domain_services)
@enduml
