@startuml
!include <archimate/Archimate>
title Data Architecture View

left to right direction

Application_Component(core, "Core / procesador")
Application_Component(domain_services, "Servicios de dominio")
Application_Component(cdc_outbox, "CDC / Transactional Outbox")
Application_Component(event_platform, "Event Platform")
Application_Component(ods, "Operational Data Store")
Application_Component(lakehouse, "Data Lakehouse")
Application_Component(dwh, "Data Warehouse")
Application_Component(feature_store, "Feature Store")
Application_Component(bi, "BI / Reporting")
Application_Component(ml, "Modelos IA / Riesgo")

Artifact(customer_data, "Datos de cliente")
Artifact(transaction_data, "Datos transaccionales")
Artifact(merchant_data, "Datos de comercio")
Artifact(risk_data, "Datos de riesgo")
Artifact(audit_data, "Datos de auditoría")
Artifact(data_product, "Data Product gobernado")

Business_Object(data_policy, "Política de datos")
Business_Object(data_catalog, "Catálogo / glosario")
Business_Object(data_lineage, "Linaje de datos")

Rel_Access(core, transaction_data)
Rel_Access(domain_services, customer_data)
Rel_Access(domain_services, merchant_data)
Rel_Access(domain_services, risk_data)
Rel_Access(cdc_outbox, transaction_data)
Rel_Flow(core, cdc_outbox)
Rel_Flow(domain_services, event_platform)
Rel_Flow(cdc_outbox, event_platform)
Rel_Flow(event_platform, ods)
Rel_Flow(event_platform, lakehouse)
Rel_Flow(lakehouse, dwh)
Rel_Flow(lakehouse, feature_store)
Rel_Flow(dwh, bi)
Rel_Flow(feature_store, ml)

Rel_Access(lakehouse, audit_data)
Rel_Access(lakehouse, data_product)
Rel_Association(data_policy, data_product)
Rel_Association(data_catalog, data_product)
Rel_Association(data_lineage, data_product)
@enduml
