@startuml
!include <archimate/Archimate>
title Business Capability View - Financial Enterprise

left to right direction

Business_Actor(customer, "Cliente")
Business_Actor(merchant, "Comercio afiliado")
Business_Actor(ops, "Operaciones")
Business_Actor(risk, "Riesgos")
Business_Actor(compliance, "Compliance")

Business_Service(digital_service, "Servicios financieros digitales")
Business_Service(merchant_service, "Servicios para comercios")
Business_Service(risk_service, "Gestión de riesgo y fraude")
Business_Service(operations_service, "Operación financiera")

Business_Process(onboarding, "Onboarding digital")
Business_Process(payments, "Procesamiento de pagos")
Business_Process(merchant_onboarding, "Afiliación de comercios")
Business_Process(reconciliation, "Conciliación y liquidación")
Business_Process(fraud_monitoring, "Monitoreo antifraude")
Business_Process(customer_support, "Atención y reclamos")

Business_Function(customer_mgmt, "Gestión de clientes")
Business_Function(product_mgmt, "Gestión de productos financieros")
Business_Function(payment_mgmt, "Gestión de pagos")
Business_Function(merchant_mgmt, "Gestión de comercios")
Business_Function(risk_mgmt, "Gestión de riesgo")
Business_Function(data_mgmt, "Gobierno de datos")
Business_Function(platform_mgmt, "Plataforma tecnológica")

Rel_Assignment(customer, digital_service)
Rel_Assignment(merchant, merchant_service)
Rel_Assignment(ops, operations_service)
Rel_Assignment(risk, risk_service)
Rel_Assignment(compliance, risk_service)

Rel_Serving(digital_service, customer)
Rel_Serving(merchant_service, merchant)
Rel_Serving(risk_service, ops)
Rel_Serving(operations_service, ops)

Rel_Composition(customer_mgmt, onboarding)
Rel_Composition(payment_mgmt, payments)
Rel_Composition(merchant_mgmt, merchant_onboarding)
Rel_Composition(payment_mgmt, reconciliation)
Rel_Composition(risk_mgmt, fraud_monitoring)
Rel_Composition(customer_mgmt, customer_support)

Rel_Serving(customer_mgmt, digital_service)
Rel_Serving(payment_mgmt, digital_service)
Rel_Serving(merchant_mgmt, merchant_service)
Rel_Serving(risk_mgmt, risk_service)
Rel_Serving(data_mgmt, risk_service)
Rel_Serving(platform_mgmt, digital_service)
@enduml
