@startuml
!include <archimate/Archimate>
title Migration Roadmap View

left to right direction

Implementation_Plateau(current, "Baseline Architecture")
Implementation_Plateau(foundation, "Transition Architecture 1: Foundation")
Implementation_Plateau(domain_modernization, "Transition Architecture 2: Domain Modernization")
Implementation_Plateau(target, "Target Architecture")

Implementation_Gap(gap_api, "APIs no gobernadas")
Implementation_Gap(gap_obs, "Observabilidad insuficiente")
Implementation_Gap(gap_identity, "Identidad fragmentada")
Implementation_Gap(gap_data, "Datos sin ownership")
Implementation_Gap(gap_core, "Acoplamiento con core legado")

Implementation_WorkPackage(wp_governance, "Architecture Governance")
Implementation_WorkPackage(wp_api, "API Management")
Implementation_WorkPackage(wp_observability, "Observability Foundation")
Implementation_WorkPackage(wp_ciam, "CIAM")
Implementation_WorkPackage(wp_events, "Event Platform")
Implementation_WorkPackage(wp_data, "Data Governance")
Implementation_WorkPackage(wp_domains, "Customer / Payment Domain Services")

Implementation_Deliverable(d1, "Principios y Architecture Board")
Implementation_Deliverable(d2, "API Gateway y catálogo")
Implementation_Deliverable(d3, "Dashboards, logs, métricas y trazas")
Implementation_Deliverable(d4, "OIDC, MFA y gestión de sesiones")
Implementation_Deliverable(d5, "Eventos versionados")
Implementation_Deliverable(d6, "Dominios de datos y owners")
Implementation_Deliverable(d7, "Servicios dominio desacoplados")

Rel_Association(current, gap_api)
Rel_Association(current, gap_obs)
Rel_Association(current, gap_identity)
Rel_Association(current, gap_data)
Rel_Association(current, gap_core)

Rel_Realization(wp_governance, d1)
Rel_Realization(wp_api, d2)
Rel_Realization(wp_observability, d3)
Rel_Realization(wp_ciam, d4)
Rel_Realization(wp_events, d5)
Rel_Realization(wp_data, d6)
Rel_Realization(wp_domains, d7)

Rel_Triggering(current, foundation)
Rel_Triggering(foundation, domain_modernization)
Rel_Triggering(domain_modernization, target)

Rel_Association(wp_governance, foundation)
Rel_Association(wp_api, foundation)
Rel_Association(wp_observability, foundation)
Rel_Association(wp_ciam, foundation)
Rel_Association(wp_events, domain_modernization)
Rel_Association(wp_data, domain_modernization)
Rel_Association(wp_domains, target)
