@startuml
!include <archimate/Archimate>
title Payment Value Stream View

left to right direction

Business_Actor(customer, "Cliente")
Business_Actor(merchant, "Comercio")
Business_Actor(card_network, "Red / marca de tarjeta")
Business_Actor(issuer_processor, "Procesador / core")

Business_Process(initiate, "Iniciar pago")
Business_Process(authenticate, "Autenticar / tokenizar")
Business_Process(authorize, "Autorizar transacción")
Business_Process(fraud_check, "Evaluar fraude")
Business_Process(capture, "Capturar operación")
Business_Process(confirm, "Confirmar pago")
Business_Process(reconcile, "Conciliar")
Business_Process(settle, "Liquidar")

Business_Object(payment_order, "Orden de pago")
Business_Object(authorization, "Autorización")
Business_Object(risk_decision, "Decisión de riesgo")
Business_Object(settlement, "Liquidación")

Business_Service(payment_service, "Servicio de pago")
Business_Service(fraud_service, "Servicio antifraude")
Business_Service(settlement_service, "Servicio de liquidación")

Rel_Triggering(customer, initiate)
Rel_Triggering(initiate, authenticate)
Rel_Triggering(authenticate, fraud_check)
Rel_Triggering(fraud_check, authorize)
Rel_Triggering(authorize, capture)
Rel_Triggering(capture, confirm)
Rel_Triggering(confirm, reconcile)
Rel_Triggering(reconcile, settle)

Rel_Access(initiate, payment_order)
Rel_Access(authorize, authorization)
Rel_Access(fraud_check, risk_decision)
Rel_Access(settle, settlement)

Rel_Serving(payment_service, initiate)
Rel_Serving(payment_service, authorize)
Rel_Serving(fraud_service, fraud_check)
Rel_Serving(settlement_service, settle)

Rel_Association(merchant, initiate)
Rel_Association(card_network, authorize)
Rel_Association(issuer_processor, authorize)
@enduml
